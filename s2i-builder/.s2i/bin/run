#!/bin/bash
set -e

APP_ROOT=/opt/app-root/src
PORT=${PORT:-8000}

cd "$APP_ROOT"

echo "---> Starting Gunicorn on port $PORT"
python manage.py migrate --noinput

exec gunicorn project.wsgi:application \
    --bind=0.0.0.0:$PORT \
    --workers=2 \
    --threads=4 \
    --pythonpath="$APP_ROOT" \
    --log-file=-

echo "Capturing git metadata..."

cd /tmp/src

COMMIT_FULL=${OPENSHIFT_BUILD_COMMIT}
COMMIT_SHORT=$(echo "$COMMIT_FULL" | cut -c1-7)

COMMIT_MSG=$(git log -1 --pretty=%s 2>/dev/null || echo "unknown")
COMMIT_AUTHOR=$(git log -1 --pretty=%an 2>/dev/null || echo "unknown")
COMMIT_DATE=$(git log -1 --pretty=%cd --date=iso 2>/dev/null || echo "unknown")

# now continue with your normal flow
echo "---> Installing Python dependencies"
pip install --no-cache-dir -r requirements.txt

echo "---> Copying application source"
cp -a /tmp/src/. /opt/app-root/src/

cd /opt/app-root/src

echo "$COMMIT_SHORT" > .git_commit
echo "$COMMIT_MSG" > .git_message
echo "$COMMIT_AUTHOR" > .git_author
echo "$COMMIT_DATE" > .git_date
echo "${OPENSHIFT_BUILD_REFERENCE}" > .git_branch
echo "${OPENSHIFT_BUILD_NAME}" > .build_name

echo "---> Collecting static files"
python3 manage.py collectstatic --noinput
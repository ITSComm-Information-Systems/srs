# ---- Custom Python Base Image Without GCC (Python 3.13) ----
FROM python:3.13-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    APP_HOME=/opt/base

WORKDIR $APP_HOME

# Copy dependencies
COPY requirements.txt .

# Install dependencies (all wheels)
RUN pip install --no-cache-dir -r requirements.txt

# OpenShift-friendly group-write permissions
RUN chgrp -R 0 $APP_HOME && chmod -R g+rwX $APP_HOME

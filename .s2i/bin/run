#!/bin/bash
set -e

APP_ROOT=/opt/app-root/src
PORT=${PORT:-8000}

cd "$APP_ROOT"

echo "---> export home"
export HOME=/tmp

# Packages installed during assemble live in the user-site under
# /opt/app-root/.local; make them importable regardless of HOME.
export PYTHONUSERBASE=/opt/app-root/.local

echo "---> Starting Gunicorn on port $PORT"

exec gunicorn project.wsgi:application \
    --bind=0.0.0.0:$PORT \
    --workers=2 \
    --threads=4 \
    --pythonpath="$APP_ROOT" \
    --log-file=- \
    --worker-tmp-dir=/tmp \
    --access-logfile=- \
    --error-logfile=-
